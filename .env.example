# Copy to .env and fill in — .env is gitignored.

# PartsLink24 credentials (required)
PARTSLINK24_COMPANY_ID=
PARTSLINK24_USERNAME=
PARTSLINK24_ACCESS_CODE=

# HTTP server
PORT=3000

# Browser automation
# true  = headless (production / server)
# false = headful  (local selector discovery + debugging)
HEADLESS=true

# Optional overrides
PARTSLINK24_BASE_URL=https://www.partslink24.com
BROWSER_NAV_TIMEOUT_MS=45000
BROWSER_ACTION_TIMEOUT_MS=15000

# Where Playwright storageState (cookies/session) is kept — auto-created
SESSION_FILE=./sessions/partslink24.json
